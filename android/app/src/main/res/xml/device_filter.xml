<?xml version="1.0" encoding="utf-8"?>
<!--
    Filtre USB pour AeroDb — puces USB-série courantes dans les projets embarqués.
    vendor-id et product-id sont en décimal (pas en hex).

    FTDI (FT232, FT2232...)         : vendor-id="1027"  (0x0403)
    Silicon Labs CP210x             : vendor-id="4292"  (0x10C4)
    CH340 / CH341                   : vendor-id="6790"  (0x1A86)
    Prolific PL2303                 : vendor-id="1659"  (0x067B)
    Arduino / Atmel (ATmega16U2...) : vendor-id="9025"  (0x2341)
    Arduino (clone)                 : vendor-id="10755" (0x2A03)
-->
<resources>
    <!-- FTDI -->
    <usb-device vendor-id="1027" />
    <!-- Silicon Labs CP210x -->
    <usb-device vendor-id="4292" />
    <!-- CH340 / CH341 -->
    <usb-device vendor-id="6790" />
    <!-- Prolific PL2303 -->
    <usb-device vendor-id="1659" />
    <!-- Arduino (officiel) -->
    <usb-device vendor-id="9025" />
    <!-- Arduino (clone) -->
    <usb-device vendor-id="10755" />
</resources>
