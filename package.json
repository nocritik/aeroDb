{
  "name": "aerodb",
  "version": "1.0.0",
  "description": "AeroDb web application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "dist-win": "electron-builder --windows",
    "dist-all": "electron-builder",
    "sync-www": "node scripts/syncToCapacitor.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/network": "^8.0.1",
    "body-parser": "^1.20.2",
    "express": "^4.18.2",
    "fs-extra": "^11.1.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.example.aerodb",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/.*",
      "!dist/**"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
